# PostgreSQL
POSTGRES_USER=ai_stock_analyst
POSTGRES_PASSWORD=ai_stock_analyst_password
POSTGRES_DB=ai_stock_analyst

# Backend database URL for running the backend natively against the Docker
# Postgres. (Docker Compose overrides this internally with the `postgres` hostname,
# so this value is safe to copy as-is via `cp .env.example .env`.)
DATABASE_URL=postgresql+psycopg://ai_stock_analyst:ai_stock_analyst_password@localhost:5432/ai_stock_analyst
# In production, set this on the hosting platform (Render env vars) — never in a
# committed file — using the managed-Postgres (Neon) string with the psycopg scheme:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Backend
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# LLM (DeepSeek, OpenAI-compatible) — get a key at https://platform.deepseek.com
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash

# Market data provider (Phase 4): yfinance needs no key and is the local default
MARKET_DATA_PROVIDER=yfinance

# Frontend public API URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Public demo hardening (all OFF locally; set on the hosting platform) ---
# DEMO_MODE=true enables anonymous session isolation, per-session LLM caps,
# and the LLM master switch (default off; enable via POST /api/admin/llm).
DEMO_MODE=false
# Shared secret for the admin endpoints (X-Admin-Token header). Unset = admin disabled.
ADMIN_TOKEN=
# Demo knobs (defaults shown)
DEMO_SESSION_TTL_DAYS=7
DEMO_REPORT_LIMIT=3
DEMO_CHAT_LLM_LIMIT=20
LLM_SWITCH_TTL_MINUTES=60
