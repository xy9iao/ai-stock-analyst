# PostgreSQL
POSTGRES_USER=ai_stock_analyst
POSTGRES_PASSWORD=ai_stock_analyst_password
POSTGRES_DB=ai_stock_analyst

# Backend database URL used inside Docker Compose
DATABASE_URL=postgresql+psycopg://ai_stock_analyst:ai_stock_analyst_password@postgres:5432/ai_stock_analyst

# Backend
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# LLM (DeepSeek, OpenAI-compatible) — get a key at https://platform.deepseek.com
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash

# Market data provider (Phase 4): yfinance needs no key and is the local default
MARKET_DATA_PROVIDER=yfinance

# Frontend public API URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
